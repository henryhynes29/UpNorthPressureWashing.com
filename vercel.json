{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "upnorthpressurewashing.com" }],
      "destination": "https://www.upnorthpressurewashing.com/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  }
}
